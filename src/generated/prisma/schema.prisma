// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("client") // client, worker, admin
  balance       Float    @default(0)
  rating        Float    @default(0)
  completedJobs Int      @default(0)
  createdAt     DateTime @default(now())
  isAdmin       Boolean  @default(false)

  tasksAsClient Task[]        @relation("ClientTasks")
  tasksAsWorker Task[]        @relation("WorkerTasks")
  transactions  Transaction[]
  taskMessages  TaskMessage[]
}

model Task {
  id             String    @id @default(cuid())
  clientId       String
  workerId       String?
  title          String
  description    String
  category       String
  deadline       DateTime
  budget         Float
  status         String    @default("open") // open, in_progress, under_review, completed, cancelled
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  clientRating   Int?
  workerRating   Int?
  escrowHeld     Boolean   @default(false)
  submissionNote String?
  submissionUrl  String?
  takenAt        DateTime?
  disputeReason  String?
  disputedAt     DateTime?

  client   User          @relation("ClientTasks", fields: [clientId], references: [id])
  worker   User?         @relation("WorkerTasks", fields: [workerId], references: [id])
  messages TaskMessage[]
}

model TaskMessage {
  id        String   @id @default(cuid())
  taskId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([senderId])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  type            String // topup, withdraw, escrow, earning, refund, fee
  amount          Float
  taskId          String?
  createdAt       DateTime @default(now())
  desc            String
  status          String   @default("pending") // pending, approved, rejected
  proofUrl        String?
  note            String?
  rejectionReason String?
  bankDetails     String?

  user User @relation(fields: [userId], references: [id])
}

model AdminSettings {
  id           String @id @default("global")
  bank_name    String
  bank_account String
  bank_owner   String
  e_wallet     String
}
